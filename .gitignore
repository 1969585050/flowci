# Binaries
*.exe
*.dll
*.so
*.dylib

# Go
vendor/
*.test
coverage.out
*.log

# Node
node_modules/
dist/
dist-ssr/
*.local

# 保留 frontend/dist/ 目录存在（即使内容由 wails build 生成）
# 原因：main.go 的 //go:embed all:frontend/dist 需要目录存在才能编译；
# .gitkeep 之外的内容全部 ignore
!frontend/dist/
frontend/dist/*
!frontend/dist/.gitkeep

# Wails
build/
# wails generate 自动产物，不入库（每次 wails dev / generate module 会重新生成）
# 新克隆后第一次跑 wails dev 即可，详见 CLAUDE.md
frontend/src/wailsjs/
# wails CLI 内部缓存（检测 frontend/package.json 是否变化）
frontend/package.json.md5

# IDE
.idea/
.vscode/
*.swp
*~
.DS_Store

# Logs
logs/
*.log

# Environment
.env
.env.local

# Misc
.toke/

# Trae IDE 配置（如果以后用别的 IDE 不再需要）
.trae/
